{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "YOUR_PROVIDER_NAME": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "YOUR_PROVIDER_NAME",
      "options": {
        "baseURL": "YOUR_API_BASE_URL",
        "apiKey": "YOUR_API_KEY"
      },
      "models": {
        "YOUR_MODEL_NAME": {
          "name": "YOUR_MODEL_NAME",
          "limit": {
            "context": 190000,
            "output": 32000
          }
        }
      }
    }
  }
}
